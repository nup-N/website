# ==================== Docker 配置 ====================
# PostgreSQL 配置
POSTGRES_DB=auth_system
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_PORT=5432

# Redis 配置
REDIS_PASSWORD=your_redis_password_here
REDIS_PORT=6379

# ==================== 后端配置 ====================
# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=admin
DB_PASSWORD=your_strong_password_here
DB_DATABASE=auth_system

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# JWT 配置（重要！）
JWT_SECRET=your_jwt_secret_key_here_at_least_64_characters
JWT_EXPIRES_IN=7d

# 应用配置
NODE_ENV=development
PORT=3000

# CORS配置（多个来源用逗号分隔）
CORS_ORIGIN=http://localhost:5173,http://192.168.10.107:5173

# ==================== 前端配置 ====================
# API配置
VITE_API_BASE_URL=/api

# ==================== 说明 ====================
# 1. 复制此文件为 .env
# 2. 修改所有密码为强密码
# 3. 确保密码一致：POSTGRES_PASSWORD = DB_PASSWORD
# 4. 生成JWT密钥：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# 5. 详细配置说明请查看 ENVIRONMENT.md
